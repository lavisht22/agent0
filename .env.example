# agent0 environment.
#
# Copy this file to `.env` and fill in the values, then `docker compose up -d`.
# Everything here is read by the single agent0 server (web UI + API in one image).

# ── Database ────────────────────────────────────────────────────────────────
# Postgres connection string. The server applies pending migrations on boot, so
# the role needs DDL rights. TLS is required (use a session pooler on :5432 for
# pooled hosts like Supabase, not the :6543 transaction pooler).
DATABASE_URL=postgres://user:password@host:5432/postgres

# ── Object storage (S3-compatible) ──────────────────────────────────────────
# Where run logs are stored. Works with any S3-compatible store (AWS S3, MinIO,
# Cloudflare R2, Backblaze B2, …).
S3_ENDPOINT=https://s3.your-provider.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional — defaults shown. forcePathStyle defaults to true (needed by MinIO);
# set to "false" for AWS S3 virtual-host-style buckets.
S3_BUCKET=runs-data
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ── Secret encryption ───────────────────────────────────────────────────────
# 32-byte key (base64 or hex) that encrypts provider credentials at rest.
# Generate with: openssl rand -base64 32
# ⚠️  BACK THIS UP. If you lose it, every stored provider credential is
#     unrecoverable and must be re-entered.
CONFIG_ENCRYPTION_KEY=

# ── Auth / sessions ─────────────────────────────────────────────────────────
# Public URL the app is served from (scheme + host, no trailing slash). Used as
# the auth base URL and to validate session origins, so it must match how users
# reach the app, e.g. https://agent0.yourdomain.com
APP_URL=https://agent0.yourdomain.com
# Secret that signs session tokens. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# ── Email (login codes via Resend) ──────────────────────────────────────────
# Login is passwordless email OTP, delivered through Resend.
RESEND_API_KEY=
# A verified Resend sender, e.g. "agent0 <login@yourdomain.com>"
RESEND_FROM_EMAIL=

# ── Optional ────────────────────────────────────────────────────────────────
# The image listens on 8080; override only if you remap it.
# PORT=8080
# Enable HTTP/2 cleartext — needed behind some proxies (e.g. GCP Cloud Run) to
# propagate client cancellation. Leave unset for normal reverse-proxy setups.
# USE_HTTP2=true
