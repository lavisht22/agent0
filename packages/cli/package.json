{
	"name": "agent0-cli",
	"version": "2.2.1",
	"description": "Command-line interface for agent0 — manage agents, prompt versions, runs, tags, providers, and MCP servers from a shell.",
	"type": "module",
	"bin": {
		"agent0": "dist/index.js"
	},
	"files": ["dist", "README.md"],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"start": "node dist/index.js",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "tsup"
	},
	"engines": {
		"node": ">=20"
	},
	"keywords": ["agent0", "cli", "ai", "agent", "llm", "prompt", "mcp"],
	"license": "ISC",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lavisht22/agent0.git",
		"directory": "packages/cli"
	},
	"bugs": {
		"url": "https://github.com/lavisht22/agent0/issues"
	},
	"homepage": "https://github.com/lavisht22/agent0/tree/main/packages/cli#readme",
	"dependencies": {
		"@clack/prompts": "^0.8.2",
		"cac": "^6.7.14",
		"ofetch": "^1.4.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.4",
		"@types/node": "^22.19.1",
		"tsup": "^8.3.5",
		"typescript": "^5.9.3"
	}
}
