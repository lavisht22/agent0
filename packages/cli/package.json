{
	"name": "agent0-cli",
	"version": "2.0.0",
	"description": "Command-line interface for agent0",
	"type": "module",
	"bin": {
		"agent0": "dist/index.js"
	},
	"files": ["dist", "README.md"],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"start": "node dist/index.js",
		"typecheck": "tsc --noEmit"
	},
	"engines": {
		"node": ">=20"
	},
	"keywords": ["agent0", "cli", "ai", "agent"],
	"license": "ISC",
	"dependencies": {
		"@clack/prompts": "^0.8.2",
		"cac": "^6.7.14",
		"ofetch": "^1.4.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.4",
		"@types/node": "^22.19.1",
		"tsup": "^8.3.5",
		"typescript": "^5.9.3"
	}
}
